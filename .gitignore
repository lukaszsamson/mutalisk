# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
cover/
*.coverdata

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
mutalisk-*.tar

# Local milestone handoff prompts.
M*_PROMPT.txt

# Dialyzer PLT cache.
/priv/plts/

# Local mutation run outputs.
/stryker.report.json
/plan.debug.json

# Real-project benchmark working copies.
/tmp/bench/

# M97 sharding-harness per-cell artifacts (reproducible via bench/shard_matrix.sh;
# the committed bench/results/matrix/summary.txt is the data record).
/bench/results/matrix/*.stryker.json
/bench/results/matrix/*.terminal.txt
